{
    "name": "oi-lab/oi-laravel-ts",
    "description": "Generate TypeScript interfaces from Laravel Eloquent models",
    "type": "library",
    "keywords": [
        "laravel",
        "typescript",
        "eloquent",
        "interfaces",
        "code-generation"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "OI Lab",
            "email": "olivier@olacombe.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "OiLab\\OiLaravelTs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OiLab\\OiLaravelTs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OiLab\\OiLaravelTs\\OiLaravelTsServiceProvider"
            ]
        },
        "oi-lab": {
            "skills": [
                {
                    "name": "oilab-laravel-ts",
                    "description": "Generate TypeScript interfaces from Eloquent models",
                    "path": "resources/stubs/ai-skill.md",
                    "rules": "resources/stubs/claude-rules.md",
                    "section": "oi-lab/oi-laravel-ts rules"
                }
            ]
        }
    },
    "scripts": {
        "sync-ai-skills": [
            "@php scripts/sync-ai-skills.php"
        ],
        "post-autoload-dump": [
            "@php scripts/sync-ai-skills.php"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
